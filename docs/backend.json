{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available for sale in the e-commerce store.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product, potentially AI-generated."
        },
        "slug": {
          "type": "string",
          "description": "A URL-friendly identifier for the product, derived from its name."
        },
        "categoryId": {
          "type": "string",
          "description": "Reference to the Category this product belongs to."
        },
        "brand": {
          "type": "string",
          "description": "The brand name of the product."
        },
        "isPublished": {
          "type": "boolean",
          "description": "Indicates whether the product is visible and available for purchase."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the product was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the product was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "slug",
        "categoryId",
        "isPublished",
        "createdAt",
        "updatedAt"
      ]
    },
    "CartItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CartItem",
      "type": "object",
      "description": "Represents an individual item within a customer's shopping cart.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the CartItem entity (often variantId)."
        },
        "productId": {
          "type": "string",
          "description": "Reference to the Product added to the cart."
        },
        "variantId": {
          "type": "string",
          "description": "Specific variant identifier."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of this product in the cart."
        },
        "price": {
          "type": "number",
          "description": "Price at the time of adding to cart."
        },
        "size": {
          "type": "string"
        },
        "customName": {
          "type": "string"
        },
        "customNumber": {
          "type": "string"
        },
        "specialNote": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "productId",
        "quantity",
        "price",
        "size"
      ]
    },
    "Customer": {
      "title": "Customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "email"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/cart/{itemId}",
        "definition": {
          "entityName": "CartItem",
          "schema": {
            "$ref": "#/backend/entities/CartItem"
          },
          "description": "Stores items in the user's persistent shopping cart.",
          "params": [
            {
              "name": "userId",
              "description": "Owner of the cart."
            },
            {
              "name": "itemId",
              "description": "Unique variant identifier."
            }
          ]
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Publicly readable product catalog."
        }
      }
    ],
    "reasoning": "Standard 3-segment paths for collections are used to ensure valid Firestore references. User data is nested for path-based authorization."
  }
}
