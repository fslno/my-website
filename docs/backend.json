
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the FSLNO e-commerce ecosystem.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "role": {
          "type": "string",
          "description": "The role of the user (customer/admin)."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of account creation.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last update.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "createdAt"
      ]
    },
    "Config": {
      "title": "Config",
      "type": "object",
      "description": "Universal configuration container for global store settings.",
      "properties": {
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "type": "object",
      "description": "Archival discount manifest.",
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percent", "fixed"] },
        "value": { "type": "number" },
        "active": { "type": "boolean" },
        "usedCount": { "type": "number" },
        "usageLimit": { "type": "number" }
      }
    },
    "WebhookEvent": {
      "title": "WebhookEvent",
      "type": "object",
      "description": "Log of incoming external signals.",
      "properties": {
        "payload": { "type": "object" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/config/{configId}",
        "definition": {
          "entityName": "Config",
          "schema": {
            "$ref": "#/backend/entities/Config"
          },
          "description": "Global storefront configurations including theme and store info."
        }
      },
      {
        "path": "/webhook_events/{eventId}",
        "definition": {
          "entityName": "WebhookEvent",
          "description": "Historical log of high-velocity external updates."
        }
      }
    ],
    "reasoning": "The Firestore structure prioritizes path-based ownership and global configuration accessibility. Sensitivity is managed via granular security rules while ensuring the storefront remains Authoritatively dynamic."
  }
}
