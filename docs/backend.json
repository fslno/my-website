
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury fashion item in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "draft", "archived"] },
        "inventory": { "type": "number" },
        "imageUrl": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "status"]
    },
    "StoreConfig": {
      "title": "Store Configuration",
      "description": "Global settings and theme configurations for the storefront.",
      "type": "object",
      "properties": {
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "bannerText": { "type": "string" },
        "bannerEnabled": { "type": "boolean" },
        "bannerBgColor": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of store products."
    },
    "/config/store": {
      "schema": "StoreConfig",
      "description": "Global store configuration."
    }
  }
}
