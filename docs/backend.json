
{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A luxury fashion item in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "comparedPrice": { "type": "number" },
        "customizationFee": { "type": "number" },
        "brand": { "type": "string" },
        "sku": { "type": "string" },
        "sizeFit": { "type": "string" },
        "categoryId": { "type": "string", "description": "Reference to a category document ID." },
        "status": { "type": "string", "enum": ["active", "draft", "archived"] },
        "inventory": { "type": "number" },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "type": { "type": "string", "enum": ["image", "video"] }
            }
          }
        },
        "features": { "type": "array", "items": { "type": "string" } },
        "seo": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "handle": { "type": "string" }
          }
        },
        "logistics": {
          "type": "object",
          "properties": {
            "weight": { "type": "number", "description": "Weight in kg" },
            "length": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "shippingClass": { "type": "string" }
          }
        },
        "createdAt": { "type": "object" }
      },
      "required": ["name", "price", "status", "categoryId"]
    },
    "Category": {
      "title": "Category",
      "description": "A product classification that can be linked to a size chart.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "sizeChartId": { "type": "string" },
        "seoTitle": { "type": "string" },
        "seoDescription": { "type": "string" }
      },
      "required": ["name"]
    },
    "SizeChart": {
      "title": "Size Chart",
      "description": "Garment measurements for specific product types.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "unit": { "type": "string", "enum": ["cm", "inch"] },
        "columns": { "type": "array", "items": { "type": "string" }, "description": "Measurement point names (e.g. Chest, Sleeve)" },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string", "description": "Size label (e.g. XS, 32, One Size)" },
              "values": { "type": "array", "items": { "type": "string" }, "description": "Measurement values corresponding to columns" }
            }
          }
        }
      },
      "required": ["name", "unit"]
    },
    "StoreConfig": {
      "title": "Store Configuration",
      "description": "Global settings and theme configurations for the storefront.",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "logoUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "bannerText": { "type": "string" },
        "bannerEnabled": { "type": "boolean" },
        "bannerBgColor": { "type": "string" }
      }
    },
    "GoogleSyncConfig": {
      "title": "Google Sync Configuration",
      "description": "Settings for Google Merchant Center and Product Studio.",
      "type": "object",
      "properties": {
        "apiConnected": { "type": "boolean" },
        "onDemandUpdates": { "type": "boolean" },
        "partialSync": { "type": "boolean" },
        "autoBackgroundRemoval": { "type": "boolean" },
        "feedHealth": { "type": "number" },
        "syncLatency": { "type": "string" },
        "activeChannelsCount": { "type": "number" },
        "lastSync": { "type": "object" },
        "issues": { "type": "array", "items": { "type": "object" } }
      }
    },
    "SocialCommerceConfig": {
      "title": "Social Commerce Configuration",
      "description": "Settings for TikTok and Meta sales channels.",
      "type": "object",
      "properties": {
        "tiktokInAppCheckout": { "type": "boolean" },
        "tiktokAccessToken": { "type": "string" },
        "metaPixelId": { "type": "string" },
        "metaAccessToken": { "type": "string" },
        "metaEmqEnabled": { "type": "boolean" },
        "customIntegrations": { "type": "array", "items": { "type": "object" } }
      }
    },
    "AnalyticsConfig": {
      "title": "Analytics Configuration",
      "description": "GA4 and funnel tracking settings.",
      "type": "object",
      "properties": {
        "ga4MeasurementId": { "type": "string" },
        "funnelTrackingEnabled": { "type": "boolean" },
        "predictiveAudiencesEnabled": { "type": "boolean" },
        "userIdTrackingEnabled": { "type": "boolean" },
        "churnProbabilityEnabled": { "type": "boolean" },
        "purchaseProbabilityEnabled": { "type": "boolean" }
      }
    },
    "ShippingConfig": {
      "title": "Shipping Configuration",
      "description": "Global carrier and pickup settings.",
      "type": "object",
      "properties": {
        "carriers": { "type": "array", "items": { "type": "string" } },
        "goGreenPlus": { "type": "boolean" },
        "localPickup": { "type": "boolean" },
        "lockerIntegration": { "type": "boolean" },
        "addressValidation": { "type": "boolean" },
        "ddpEnabled": { "type": "boolean" }
      }
    },
    "PaymentConfig": {
      "title": "Payment Configuration",
      "description": "Stripe, PayPal, and Express Checkout settings.",
      "type": "object",
      "properties": {
        "stripeEnabled": { "type": "boolean" },
        "stripeMode": { "type": "string", "enum": ["test", "live"] },
        "stripePublishableKey": { "type": "string" },
        "stripeSecretKey": { "type": "string" },
        "paypalEnabled": { "type": "boolean" },
        "paypalMode": { "type": "string", "enum": ["sandbox", "live"] },
        "paypalClientId": { "type": "string" },
        "paypalPayLaterEnabled": { "type": "boolean" },
        "applePayEnabled": { "type": "boolean" },
        "googlePayEnabled": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of store products."
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Collection of product categories."
    },
    "/sizeCharts/{chartId}": {
      "schema": "SizeChart",
      "description": "Collection of garment size charts."
    },
    "/config/store": {
      "schema": "StoreConfig",
      "description": "Global store configuration."
    },
    "/config/google-sync": {
      "schema": "GoogleSyncConfig",
      "description": "Google Merchant Center sync settings."
    },
    "/config/social-commerce": {
      "schema": "SocialCommerceConfig",
      "description": "Social commerce and CAPI settings."
    },
    "/config/analytics": {
      "schema": "AnalyticsConfig",
      "description": "GA4 and analytics settings."
    },
    "/config/shipping": {
      "schema": "ShippingConfig",
      "description": "Global logistics and shipping settings."
    },
    "/config/payments": {
      "schema": "PaymentConfig",
      "description": "Global payment gateway settings."
    }
  }
}
