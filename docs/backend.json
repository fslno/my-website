
{
  "entities": {
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a single product available for sale in the e-commerce store.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Product entity."
        },
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product, potentially AI-generated."
        },
        "slug": {
          "type": "string",
          "description": "A URL-friendly identifier for the product, derived from its name."
        },
        "categoryId": {
          "type": "string",
          "description": "Reference to the Category this product belongs to."
        },
        "brand": {
          "type": "string",
          "description": "The brand name of the product."
        },
        "isPublished": {
          "type": "boolean",
          "description": "Indicates whether the product is visible and available for purchase."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the product was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp when the product was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "description",
        "slug",
        "categoryId",
        "isPublished",
        "createdAt",
        "updatedAt"
      ]
    },
    "CartItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CartItem",
      "type": "object",
      "description": "Represents an individual item within a customer's shopping cart.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the CartItem entity (often variantId)."
        },
        "productId": {
          "type": "string",
          "description": "Reference to the Product added to the cart."
        },
        "variantId": {
          "type": "string",
          "description": "Specific variant identifier."
        },
        "quantity": {
          "type": "number",
          "description": "The quantity of this product in the cart."
        },
        "price": {
          "type": "number",
          "description": "Price at the time of adding to cart."
        },
        "size": {
          "type": "string"
        },
        "customName": {
          "type": "string"
        },
        "customNumber": {
          "type": "string"
        },
        "specialNote": {
          "type": "string"
        },
        "isPromo": {
          "type": "boolean",
          "description": "Flag for automatically added BOGO items."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "productId",
        "quantity",
        "price",
        "size"
      ]
    },
    "Coupon": {
      "title": "Coupon",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["percent", "fixed"] },
        "value": { "type": "number" },
        "active": { "type": "boolean" },
        "usageLimit": { "type": "number" },
        "usedCount": { "type": "number" }
      },
      "required": ["code", "type", "value", "active"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "brand": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "image"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "customer": { "type": "object" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "discountTotal": { "type": "number" },
        "couponCode": { "type": "string" },
        "tax": { "type": "number" },
        "shipping": { "type": "number" },
        "total": { "type": "number" },
        "deliveryMethod": { "type": "string" },
        "courier": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "total", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/cart/{itemId}",
        "definition": {
          "entityName": "CartItem",
          "schema": {
            "$ref": "#/backend/entities/CartItem"
          }
        }
      },
      {
        "path": "/coupons/{code}",
        "definition": {
          "entityName": "Coupon",
          "schema": {
            "$ref": "#/backend/entities/Coupon"
          }
        }
      },
      {
        "path": "/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": {
            "$ref": "#/backend/entities/Order"
          }
        }
      }
    ]
  }
}
