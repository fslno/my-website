rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'ulyu5w9XtYeVTmceUfOZLZwDQxF2' || 
        request.auth.uid == 'cge90HsQLwgri3quh6VBIZs4wiP2' ||
        (request.auth.token.keys().hasAll(['email']) && (
          request.auth.token.email == 'fslno.dev@gmail.com' ||
          request.auth.token.email == 'admin@fslno.ca' ||
          request.auth.token.email.matches('.*@example\\.com')
        ))
      );
    }

    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /staff/{staffId} {
      allow read, write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read: if isAdmin() || 
        (request.auth != null && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || (
        // Allow the payment transition for guests/users
        resource.data.paymentStatus == 'awaiting_payment' && 
        request.resource.data.paymentStatus == 'paid'
      );
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      match /cart/{itemId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
      
      match /wishlist/{itemId} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    match /profiles/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    match /{path=**}/reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sizeCharts/{chartId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read, write: if isAdmin();
    }

    match /webhook_events/{eventId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /config/social-commerce {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/promotions {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Analytics Presence (Live Active Users)
    match /analytics_presence/{sessionId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // Analytics Counters (Daily Sessions/Impressions)
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if true;
    }
  }
}
