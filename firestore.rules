rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FSLNO E-COMMERCE SECURITY RULES
     * 
     * Core Philosophy:
     * This ruleset implements a robust, multi-tier security model for an e-commerce platform. 
     * Evaluation is strictly prioritized for administrative authority.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Authoritative check for administrative authority.
     * Evaluates the hardcoded master UID manifest before checking the forensic roles manifest.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'ulyu5w9XtYeVTmceUfOZLZwDQxF2' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isExistingOwner(userId) || isExistingAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isExistingAdmin();
      
      match /cart/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description high-security collection for administrative role assignment.
     */
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
    }

    /**
     * @description Global storefront settings.
     */
    match /config/{configId} {
      allow get: if true;
      allow list, write: if isAdmin();
    }

    /**
     * @description Product catalog data.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Product categories and metadata.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Size guide templates.
     */
    match /sizeCharts/{chartId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description High-fidelity transaction manifests.
     */
    match /orders/{orderId} {
      allow create: if true;
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || (resource.data.userId == 'guest');
      allow list: if isAdmin() || (isSignedIn() && (request.query.filters.userId == request.auth.uid || request.query.limit <= 500));
      allow update, delete: if isAdmin();
    }
    
    /**
     * @description Archival feedback manifest.
     */
    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    /**
     * @description Featured customer testimonials.
     */
    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    /**
     * @description Internal team access.
     */
    match /staff/{staffId} {
      allow read, write: if isAdmin();
    }
    
    /**
     * @description Partner connectivity manifest.
     */
    match /partners/{partnerId} {
      allow read, write: if isAdmin();
    }
  }
}