/**
 * FIRESTORE SECURITY RULES
 * 
 * Core Philosophy:
 * This ruleset implements a dual-layer security model designed for a robust e-commerce platform. 
 * It prioritizes Authorization Independence and Structural Segregation to ensure high performance 
 * and clear security boundaries.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- COLLECTION RULES ---

    match /products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;

      match /variants/{variantId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource != null;
      }

      match /images/{imageId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource != null;
      }
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /sizeCharts/{sizeChartId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /collections/{collectionId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /inventory/{inventoryId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /addresses/{addressId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId);
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if (isOwner(userId) || isAdmin()) && resource != null;

        match /items/{orderItemId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId);
          allow update, delete: if (isOwner(userId) || isAdmin()) && resource != null;
        }
      }

      // Simplified cart structure: users/{userId}/cart/{itemId}
      match /cart/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /shippingZones/{zoneId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;

      match /rates/{rateId} {
        allow get, list: if true;
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn() && resource != null;
      }
    }

    match /paymentGatewayConfigs/{configId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /storeSettings/{settingId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /banners/{bannerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /socialSyncs/{platformId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource != null;
    }

    match /roles_admin/{uid} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Config singleton permissions - relaxed for development
    match /config/{configId} {
      allow get: if true;
      allow list: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
