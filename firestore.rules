
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'fslno.dev@gmail.com' ||
        request.auth.token.email == 'fslno.owner@gmail.com' ||
        request.auth.uid == 'ulyu5w9XtYeVTmceUfOZLZwDQxF2' ||
        request.auth.uid == 'vu6glqmWKBULFaqyvwhHzHu37ox1' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /orders/{orderId} {
      allow create: if request.resource.data.userId == 'guest' || isOwner(request.resource.data.userId);
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Allow listing if user is admin OR if the query is strictly filtered to their own UID with a safe limit
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100 && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /coupons/{code} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /sizeCharts/{sizeChartId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /cart/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow get: if true;
      allow write: if isAdmin();
    }
  }
}
