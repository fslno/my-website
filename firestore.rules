rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Strictly restricted to UID 'ulyu5w9XtYeVTmceUfOZLZwDQxF2'
      return isSignedIn() && request.auth.uid == 'ulyu5w9XtYeVTmceUfOZLZwDQxF2';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION RULES ---

    match /orders/{orderId} {
      allow create: if request.resource.data.userId == 'guest' || isOwner(request.resource.data.userId);
      
      // Separate Admin and Member list protocols to prevent query plan ambiguity
      allow list: if isAdmin();
      allow list: if isSignedIn() && request.query.limit <= 100 && resource.data.userId == request.auth.uid;
      
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /coupons/{code} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /sizeCharts/{sizeChartId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Only administrators can list the unified member manifest
      allow list: if isAdmin();
      
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      match /cart/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      match /wishlist/{productId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /partners/{partnerId} {
      allow read, write: if isAdmin();
    }

    match /config/{configId} {
      allow get: if true;
      allow write: if isAdmin();
    }
  }
}
