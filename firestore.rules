rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FSLNO E-COMMERCE SECURITY RULES - V2 (Draft & Publish)
     * 
     * Core Philosophy:
     * 1. Public can ONLY read 'live_' collections.
     * 2. Admin has full authority over all collections.
     * 3. Transactional data (orders, users) is shared across environments.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'ulyu5w9XtYeVTmceUfOZLZwDQxF2' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Production (Live) Collection Rules ---
    // Publicly accessible read-only snapshots.

    match /live_products/{id} { allow get, list: if true; }
    match /live_categories/{id} { allow get, list: if true; }
    match /live_config/{id} { allow get: if true; allow list: if true; }
    match /live_testimonials/{id} { allow get, list: if true; }
    match /live_sizeCharts/{id} { allow get, list: if true; }

    // --- Staging (Studio) Collection Rules ---
    // Strictly restricted to administrative authority.

    match /products/{id} { allow read, write: if isAdmin(); }
    match /categories/{id} { allow read, write: if isAdmin(); }
    match /config/{id} { allow read, write: if isAdmin(); }
    match /testimonials/{id} { allow read, write: if isAdmin(); }
    match /sizeCharts/{id} { allow read, write: if isAdmin(); }

    // --- Shared Transactional Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();
      
      match /cart/{itemId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /wishlist/{itemId} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    match /roles_admin/{userId} { allow read, write: if isAdmin(); }
    match /orders/{orderId} {
      allow create: if true;
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || (resource.data.userId == 'guest');
      allow list: if isAdmin() || (isSignedIn() && (request.query.filters.userId == request.auth.uid || request.query.limit <= 500));
      allow update, delete: if isAdmin();
    }
    
    match /reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    match /staff/{id} { allow read, write: if isAdmin(); }
    match /partners/{id} { allow read, write: if isAdmin(); }
    match /coupons/{id} { allow get: if true; allow list, write: if isAdmin(); }
    match /mail/{id} { allow create: if true; allow read, update, delete: if isAdmin(); }
  }
}