rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid in ['ulyu5w9XtYeVTmceUfOZLZwDQxF2', 'cge90HsQLwgri3quh6VBIZs4wiP2'] ||
        request.auth.token.email in ['fslno.dev@gmail.com', 'admin@fslno.ca', 'kingfslno@gmail.com'] ||
        (request.auth.token.email != null && (
          request.auth.token.email.matches('.*@fslno\\.ca$') ||
          request.auth.token.email.matches('.*@example\\.com$')
        ))
      );
    }

    // Publicly readable assets generated by admin
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /author_images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /storefront/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sizeCharts/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /invoices/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Default: Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
